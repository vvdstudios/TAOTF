# TAOTF — The Archive of the Future
# Copy to .env and fill in values. Do not commit .env.

# ─── LLM Backend ─────────────────────────────────────────────────────────────
# Default: Ollama (open source, local). No API key needed.
# Install Ollama: https://ollama.com then run: ollama pull qwen2.5

# Backend: "ollama" (default) or "openai"
# TAOTF_LLM_BACKEND=ollama

# Model: default is "qwen2.5" for Ollama, "gpt-4o-mini" for OpenAI
# TAOTF_LLM_MODEL=qwen2.5

# Base URL override (e.g. remote Ollama server):
# TAOTF_LLM_BASE_URL=http://localhost:11434/v1

# Required only when TAOTF_LLM_BACKEND=openai:
# OPENAI_API_KEY=sk-...

# ─── Data ─────────────────────────────────────────────────────────────────────
# Optional: data directory and signals file (default: current dir, taotf_signals.jsonl)
# TAOTF_DATA_DIR=.
# TAOTF_SIGNALS_FILE=taotf_signals.jsonl

# ─── API Server ───────────────────────────────────────────────────────────────
# Optional: API server (default port 8000)
# PORT=8000

# Agent verification (closed-box): threshold for pass/fail (default 0.35). Not exposed to clients.
# TAOTF_VERIFY_THRESHOLD=0.35

# ─── MCP Server ───────────────────────────────────────────────────────────────
# MCP server: URL of TAOTF API when not localhost:8000
# TAOTF_API_URL=http://localhost:8000
